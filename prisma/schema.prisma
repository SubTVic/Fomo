generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Hochschulgruppen ────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  color       String?  // Hex color for UI, e.g. "#E63946"
  icon        String?  // Icon identifier, e.g. "globe", "music"
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  groups Group[]

  @@map("categories")
}

model Group {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  shortDescription String   @db.VarChar(200)
  longDescription  String?  @db.Text
  categoryId       String
  contactEmail     String?
  websiteUrl       String?
  instagramUrl     String?
  logoUrl          String?
  memberCount      Int?
  meetingSchedule  String?  // e.g. "Jeden Dienstag 19:00"
  isActive         Boolean  @default(true)
  isVerified       Boolean  @default(false) // Profile confirmed by the group itself
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // ─── Matching-Attribute (aus CSV-Import) ─────────────────────
  career                  Boolean @default(false)
  tech                    Boolean @default(false)
  socialImpact            Boolean @default(false)
  party                   Boolean @default(false)
  religion                Boolean @default(false)
  sports                  Boolean @default(false)
  networking              Boolean @default(false)
  arts                    Boolean @default(false)
  music                   Boolean @default(false)
  timeLow                 Boolean @default(false)
  handsOn                 Boolean @default(false)
  outdoor                 Boolean @default(false)
  international           Boolean @default(false)
  beginnerFriendly        Boolean @default(false)
  competitive             Boolean @default(false)
  financialCost           Boolean @default(false)
  leadershipOpportunities Boolean @default(false)

  // Kategoriale Attribute
  language       String? // "german", "both", "english"
  eventFrequency String? // "low", "medium", "high"
  groupSize      String? // "small", "medium", "large"

  // Event-Daten (nächstes bekanntes Event)
  nextEventTitle    String?
  nextEventDate     String?
  nextEventTime     String?
  nextEventLocation String?
  nextEventUrl      String?
  nextEventIsOpen   Boolean @default(false)

  // ─── Registrierung ───────────────────────────────────────────
  registeredVia     String?   // "import" | "survey" | "admin"
  registeredAt      DateTime?
  contactPerson     String?   // Ansprechperson (intern, nicht öffentlich)
  contactPersonRole String?   // z.B. "Vorsitzende:r"
  onboardingInfo    String?   @db.Text
  motto             String?   // Slogan der Gruppe
  foundedYear       Int?

  category     Category          @relation(fields: [categoryId], references: [id])
  profiles     GroupProfile[]
  pilotAnswers GroupPilotAnswer[]

  @@index([categoryId])
  @@index([isActive])
  @@index([registeredVia])
  @@map("groups")
}

// Answers from groups to pilot survey questions (bridges pilot ↔ quiz)
model GroupPilotAnswer {
  id         String @id @default(cuid())
  groupId    String
  questionId String // e.g. "D1Q1"
  value      String // "1"-"5"

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, questionId])
  @@index([groupId])
  @@map("group_pilot_answers")
}

// ─── Quiz-Fragen ─────────────────────────────────────────────────

enum QuestionType {
  LIKERT        // 5-point scale (stimme nicht zu ↔ stimme voll zu)
  SINGLE_CHOICE // One answer from multiple options
  MULTI_CHOICE  // Multiple answers possible
  YES_NO        // Binary yes/no
  SLIDER        // Numeric value on a range
}

model Question {
  id          String       @id @default(cuid())
  text        String       // The question text shown to users
  type        QuestionType
  order       Int          @default(0)
  isRequired  Boolean      @default(true)
  helpText    String?      // Optional explanation shown below the question
  categoryTag String?      // Thematic tag, e.g. "politics", "social", "time"
  weight      Float        @default(1.0) // Default weight for matching
  // For SLIDER type: defines the range
  sliderMin   Int?         @default(0)
  sliderMax   Int?         @default(100)
  sliderStep  Int?         @default(1)
  sliderMinLabel String?   // e.g. "Gar nicht wichtig"
  sliderMaxLabel String?   // e.g. "Sehr wichtig"
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  options  QuestionOption[]
  profiles GroupProfile[]

  @@map("questions")
}

model QuestionOption {
  id         String @id @default(cuid())
  questionId String
  label      String // Display text, e.g. "Sport & Bewegung"
  value      String // Stored value for matching, e.g. "sport"
  order      Int    @default(0)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("question_options")
}

// ─── Matching-Profile ────────────────────────────────────────────

model GroupProfile {
  id         String @id @default(cuid())
  groupId    String
  questionId String

  // The group's "answer" to this question.
  // For LIKERT: "1"-"5"
  // For YES_NO: "0" or "1"
  // For SLIDER: numeric string, e.g. "75"
  // For SINGLE_CHOICE: the option value, e.g. "sport"
  // For MULTI_CHOICE: comma-separated values, e.g. "sport,culture,tech"
  answerValue String

  // Optional per-question weight override for this group
  weight Float @default(1.0)

  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([groupId, questionId])
  @@index([groupId])
  @@index([questionId])
  @@map("group_profiles")
}

// ─── Admin & Auth ────────────────────────────────────────────────

enum AdminRole {
  SUPER_ADMIN // StuRa staff, full access
  EDITOR      // Can edit groups and questions
}

model Admin {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String?   // For credentials login (Phase 1)
  ssoId        String?   @unique // For Shibboleth/SAML (Phase 2)
  role         AdminRole @default(EDITOR)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("admins")
}

// ─── Analytics (anonymous) ───────────────────────────────────────

model QuizSession {
  id           String    @id @default(cuid())
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  questionCount Int      @default(0) // How many questions were answered
  resultCount  Int       @default(0) // How many results were shown
  // No personal data, no IP, no user agent
  // Just aggregate stats for understanding usage

  @@map("quiz_sessions")
}

// ─── Pilot-Fragebogen (Dimensionen & Fragen) ─────────────────────
// Pilot survey questions are managed via the admin dashboard

model PilotDimension {
  id          String @id  // "D1", "D2", etc.
  label       String      // "Zeitbudget & Verbindlichkeit"
  emoji       String @default("")
  description String @default("")
  blockIndex  Int    @default(0) // 0–3: which variant block this dimension belongs to
  order       Int    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions PilotSurveyQuestion[]

  @@map("pilot_dimensions")
}

model PilotSurveyQuestion {
  id          String   @id  // "D1Q1", "D1Q2", etc. or "S1" for standalone
  dimensionId String?       // null = standalone item (no dimension)
  text        String   @db.Text
  order       Int      @default(0)
  isInverse   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  dimension PilotDimension? @relation(fields: [dimensionId], references: [id], onDelete: Cascade)

  @@index([dimensionId])
  @@map("pilot_survey_questions")
}

// ─── Pilot-Umfrage (Sessions & Antworten) ────────────────────────
// Responses from the pilot survey (4 UI variants: scroll/classic/swipe/chat)

model PilotSession {
  id          String    @id @default(cuid())
  variant     String    // Legacy single-variant or "mixed" for multi-variant flow
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  // Multi-variant flow: JSON array of variant keys in the order shown
  variantOrder     String? // e.g. '["swipe","scroll","chat","classic"]'
  preferredVariant String? // User's favourite variant, e.g. "swipe"
  preferenceReason String? @db.Text // Why they preferred it

  // Demographics (collected at the end)
  semester   String? // e.g. "1", "3", "5+"
  isMember   String? // "yes" | "no" | "was"
  groupNames String? // free text, comma-separated

  // Open feedback
  feedbackConfusing String? @db.Text
  feedbackMissing   String? @db.Text

  answers PilotAnswer[]

  @@index([variant])
  @@index([completedAt])
  @@map("pilot_sessions")
}

model PilotAnswer {
  id         String @id @default(cuid())
  sessionId  String
  questionId String // e.g. "D1Q1"
  value      String // Likert "1"-"5" or free text

  session PilotSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionId])
  @@index([sessionId])
  @@map("pilot_answers")
}
